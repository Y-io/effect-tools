{
  "name": "@pkg/effect-query",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start:build": "vite build --config prototype/start-app/vite.config.ts",
    "start:dev": "vite dev --config prototype/start-app/vite.config.ts",
    "start:ssr": "bun prototype/start-app/verify-ssr.ts",
    "start:typecheck": "tsc --noEmit -p prototype/start-app/tsconfig.json",
    "test": "bun test test",
    "lint": "oxlint src test prototype",
    "format": "oxfmt src test prototype",
    "format:check": "oxfmt --check src test prototype",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "bun run typecheck && bun run test && bun run lint && bun run format:check && bun run start:build && bun run start:typecheck && bun run start:ssr"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react-dom": "^19.2.7",
    "react-test-renderer": "^19.2.7",
    "vite": "^8.1.4"
  }
}
