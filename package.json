{
  "name": "effect-stack",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "http-api-client:verify": "bun run --cwd packages/http-api-client verify",
    "prepare": "effect-tsgo patch"
  },
  "dependencies": {
    "@effect/platform": "^0.96.2",
    "@effect/platform-bun": "^0.90.0",
    "effect": "3.21.4"
  },
  "devDependencies": {
    "@effect/tsgo": "0.18.0",
    "@types/bun": "latest",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "7.1.0-dev.20260708.3"
  },
  "packageManager": "bun@1.3.14"
}
